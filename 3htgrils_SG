<!-- Thank You -->
<div class="thank-you" id="thankYou">
  <div class="ty-icon">✿</div>
  <div class="ty-title">謝謝妳的回饋</div>
  <p class="ty-text">
    今天最美的顏色，是妳自己。<br>
    每一個字，我都會認真讀。
  </p>

  <!-- Conversion CTA — only shown if Q11 = 想要！我要預約 -->
  <div class="ty-cta-box" id="tyCtaBox">
    <div class="ty-cta-eyebrow">專屬妳的禮物</div>
    <div class="ty-cta-title">免費一對一線上預諮詢<br>已經為妳保留名額</div>
    <a href="https://calendly.com/floralway-image/30min" target="_blank" class="ty-cta-btn">立即預約 →</a>
    <div class="ty-cta-sub">30 分鐘線上或實體諮詢 · 完全免費</div>
  </div>

  <div class="ty-brand">質穎形象顏究室® · Floral Way Image Studio</div>
</div>

<script>
  // ★ 貼上你的 Google Apps Script 網址
  const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyyNndXC61TUWxR-7dwtBTBEJDrath_EX3a1CusvHmHBXFQGB2HFOo1UDHeBLIV3g8QRA/exec';

  const answers = {
    age: null, q1: null, q2: null, q3: '', q4: [], q5: '',
    q6: null, q8: null, q9: null, q10: null,
    q11: null, q12: null, q13: '', consent: null
  };

  const REQUIRED = ['age','q1','q2','q3','q6','q8','q9','q10','q11','q12','q13','consent'];

  function selectRating(q, v) {
    answers[q] = v;
    const row = document.getElementById(`${q}-row`);
    row.querySelectorAll('.rating-btn').forEach((btn, i) => btn.classList.toggle('selected', (i+1) === v));
    clearError(`card-${q}`);
    updateProgress();
  }

  function selectNPS(q, v) {
    answers[q] = v;
    document.querySelectorAll(`#${q}-row .nps-btn`).forEach((btn, i) => btn.classList.toggle('selected', i === v));
    clearError(`card-${q}`);
    updateProgress();
  }

  function selectRadio(el, q) {
    const val = el.querySelector('input').value;
    answers[q] = val;
    const wrapId = q === 'age' ? 'age-options' : `${q}-options`;
    document.querySelectorAll(`#${wrapId} .option-item`).forEach(item => item.classList.remove('selected'));
    el.classList.add('selected');
    clearError(q === 'age' ? 'card-age' : `card-${q}`);
    updateProgress();
  }

  function toggleCheckbox(el, q) {
    const val = el.dataset.value;
    const isSelected = el.classList.contains('selected');
    if (isSelected) {
      el.classList.remove('selected');
      answers[q] = answers[q].filter(v => v !== val);
    } else {
      el.classList.add('selected');
      if (!answers[q].includes(val)) answers[q].push(val);
    }
    updateProgress();
  }

  function selectConsent(v) {
    answers.consent = v;
    document.getElementById('consent-yes').className = 'consent-btn' + (v==='yes' ? ' selected-yes' : '');
    document.getElementById('consent-no').className = 'consent-btn' + (v==='no' ? ' selected-no' : '');
    clearError('card-q14');
    updateProgress();
  }

  function clearError(cardId) { document.getElementById(cardId)?.classList.remove('has-error'); }

  function updateProgress() {
    answers.q3  = document.getElementById('q3')?.value.trim()  || '';
    answers.q5  = document.getElementById('q5')?.value.trim()  || '';
    answers.q13 = document.getElementById('q13')?.value.trim() || '';

    let filled = 0;
    REQUIRED.forEach(k => {
      const v = answers[k];
      if (k === 'q3' || k === 'q13') { if (v && v.length > 0) filled++; }
      else if (k === 'consent') { if (v !== null) filled++; }
      else { if (v !== null && v !== undefined) filled++; }
    });
    const pct = Math.round((filled / REQUIRED.length) * 100);
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressPct').textContent = pct + '%';
  }

  const fieldMap = {
    age: 'card-age', q1: 'card-q1', q2: 'card-q2', q3: 'card-q3',
    q6: 'card-q6', q8: 'card-q8', q9: 'card-q9', q10: 'card-q10',
    q11: 'card-q11', q12: 'card-q12', q13: 'card-q13', consent: 'card-q14'
  };

  function submitForm() {
    answers.q3  = document.getElementById('q3')?.value.trim()  || '';
    answers.q13 = document.getElementById('q13')?.value.trim() || '';

    let valid = true;
    REQUIRED.forEach(k => {
      const v = answers[k];
      let filled = false;
      if (k === 'q3' || k === 'q13') filled = v && v.length > 0;
      else if (k === 'consent') filled = v !== null;
      else filled = v !== null && v !== undefined;

      const cardId = fieldMap[k];
      if (!filled) { document.getElementById(cardId)?.classList.add('has-error'); valid = false; }
      else { document.getElementById(cardId)?.classList.remove('has-error'); }
    });

    if (!valid) {
      const firstError = document.querySelector('.q-card.has-error');
      if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const btn = document.querySelector('.submit-btn');
    btn.textContent = '送出中……';
    btn.disabled = true;

    const q4Other = document.getElementById('q4-other-text')?.value.trim();
    const q4Final = answers.q4.map(v => v === 'other-q4' ? (q4Other ? '其他：' + q4Other : '其他') : v);

    const q6Other = document.getElementById('q6-other-text')?.value.trim();
    const q6Final = answers.q6 === 'other-q6' ? (q6Other ? '其他：' + q6Other : '其他') : answers.q6;

    const payload = {
      timestamp: new Date().toLocaleString('zh-TW', {timeZone:'Asia/Taipei'}),
      age_range: answers.age,
      q1_before: answers.q1,
      q2_after: answers.q2,
      q3_biggest_change: answers.q3,
      q4_mindset_shift: q4Final.join('、'),
      q5_aha: answers.q5,
      q6_biggest_help_choice: q6Final,
      q8_practical: answers.q8,
      q9_retake_course: answers.q9,
      q10_clarity: answers.q10,
      q11_consult_interest: answers.q11,
      q12_nps: answers.q12,
      q13_quote: answers.q13,
      q14_consent: answers.consent === 'yes' ? '同意' : '不同意'
    };

    fetch(SCRIPT_URL, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(() => showThankYou())
    .catch(() => showThankYou());
  }

  function showThankYou() {
    document.getElementById('surveyForm').style.display = 'none';
    document.querySelector('.progress-wrap').style.display = 'none';

    // ★ 轉換邏輯：若學員選擇「想要！我要預約」，顯示預約 CTA
    if (answers.q11 === '想要！我要預約') {
      document.getElementById('tyCtaBox').classList.add('show');
    }

    document.getElementById('thankYou').classList.add('show');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
